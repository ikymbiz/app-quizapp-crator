{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/learning-problem-package-v1.schema.json",
  "title": "Learning Problem Package v1",
  "description": "汎用学習問題パッケージ形式。文章・式・画像・動画・音声と、数値入力・四択・文字入力を組み合わせられる。",
  "type": "object",
  "required": ["type", "schemaVersion", "packageId", "title", "units"],
  "properties": {
    "type": { "const": "learning.problemPackage" },
    "schemaVersion": { "const": 1 },
    "packageId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "locale": { "type": "string", "default": "ja-JP" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "src"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["image", "video", "audio"] },
          "src": { "type": "string" },
          "alt": { "type": "string" },
          "caption": { "type": "string" },
          "mimeType": { "type": "string" },
          "credit": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "monsterUnitMap": {
      "type": "object",
      "description": "任意。MathBattleで使う場合のみ、monsterId -> unitId を指定できる。",
      "additionalProperties": { "type": "string" }
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/unit" }
    }
  },
  "$defs": {
    "unit": {
      "type": "object",
      "required": ["id", "title", "expectedAnswerSeconds", "answerType", "generator"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "grade": { "type": ["string", "number"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "expectedAnswerSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "answerType": { "enum": ["numeric", "choice", "text"] },
        "contentTypes": {
          "type": "array",
          "items": { "enum": ["text", "formula", "image", "video", "audio"] }
        },
        "generator": {
          "oneOf": [
            { "$ref": "#/$defs/staticGenerator" },
            { "$ref": "#/$defs/arithmeticGenerator" }
          ]
        }
      },
      "additionalProperties": true
    },
    "staticGenerator": {
      "type": "object",
      "required": ["kind", "questions"],
      "properties": {
        "kind": { "const": "static" },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/question" }
        }
      },
      "additionalProperties": true
    },
    "arithmeticGenerator": {
      "type": "object",
      "required": ["kind", "operations", "operandRange"],
      "properties": {
        "kind": { "const": "arithmetic" },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["+", "-", "*", "/"] }
        },
        "operandRange": {
          "type": "array",
          "prefixItems": [{ "type": "number" }, { "type": "number" }],
          "minItems": 2,
          "maxItems": 2
        },
        "nonNegative": { "type": "boolean" },
        "choiceCount": { "type": "integer", "minimum": 2, "maximum": 8 }
      },
      "additionalProperties": true
    },
    "question": {
      "type": "object",
      "required": ["content", "response"],
      "properties": {
        "id": { "type": "string" },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/contentBlock" }
        },
        "response": { "$ref": "#/$defs/response" },
        "expectedAnswerSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "explanation": { "type": "string" },
        "difficulty": { "type": ["string", "number"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "contentBlock": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["text", "formula", "image", "video", "audio"] },
        "text": { "type": "string" },
        "src": { "type": "string" },
        "assetId": { "type": "string" },
        "alt": { "type": "string" },
        "caption": { "type": "string" }
      },
      "additionalProperties": true
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "correct"],
          "properties": {
            "type": { "const": "numeric" },
            "correct": { "type": "number" },
            "tolerance": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "choices", "correctId"],
          "properties": {
            "type": { "const": "choice" },
            "choices": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "properties": {
                  "id": { "type": "string" },
                  "label": { "type": "string" },
                  "value": {}
                },
                "additionalProperties": true
              }
            },
            "correctId": { "type": "string" },
            "correctValue": {}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "answers"],
          "properties": {
            "type": { "const": "text" },
            "answers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "caseSensitive": { "type": "boolean" },
            "normalizeKana": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": true
}
